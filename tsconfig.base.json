{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/editor/src/*"],
      "@ggez/dev-sync": ["packages/dev-sync/src/index.ts"],
      "@ggez/dev-sync/node": ["packages/dev-sync/src/node.ts"],
      "@ggez/shared": ["packages/shared/src/index.ts"],
      "@ggez/editor-core": ["packages/editor-core/src/index.ts"],
      "@ggez/geometry-kernel": ["packages/geometry-kernel/src/index.ts"],
      "@ggez/gameplay-runtime": ["packages/gameplay-runtime/src/index.ts"],
      "@ggez/render-pipeline": ["packages/render-pipeline/src/index.ts"],
      "@ggez/runtime-build": ["packages/runtime-build/src/index.ts"],
      "@ggez/runtime-format": ["packages/runtime-format/src/index.ts"],
      "@ggez/runtime-physics-rapier": ["packages/runtime-physics-rapier/src/index.ts"],
      "@ggez/runtime-streaming": ["packages/runtime-streaming/src/index.ts"],
      "@ggez/three-runtime": ["packages/three-runtime/src/index.ts"],
      "@ggez/tool-system": ["packages/tool-system/src/index.ts"],
      "@ggez/workers": ["packages/workers/src/index.ts"],
      "@ggez/runtime-audio": ["packages/runtime-audio/src/index.ts"],
      "@ggez/runtime-particles": ["packages/runtime-particles/src/index.ts"],
      "@ggez/prefab-system": ["packages/prefab-system/src/index.ts"]
    }
  }
}
